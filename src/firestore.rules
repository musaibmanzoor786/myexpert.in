rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return request.auth != null && request.auth.token.email == 'suhaibmanzoormugloo13@gmail.com'; }
    function isOwner(userId) { return request.auth != null && request.auth.uid == userId; }

    // --- Experts ---
    match /experts/{expertId} {
      allow read: if true;
      allow create, update, delete: if isOwner(expertId) || isAdmin();
    }

    // --- Reviews ---
    match /experts/{expertId}/reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource != null && resource.data.customerId == request.auth.uid;
    }

    // --- Users ---
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
    }

    // --- Bookings ---
    match /bookings/{bookingId} {
      allow read: if request.auth != null && (resource.data.participantIds.hasAny([request.auth.uid]) || isAdmin());
      allow create: if isSignedIn();
      allow update: if request.auth != null && (resource.data.participantIds.hasAny([request.auth.uid]) || isAdmin());
    }

    // --- Services ---
    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
